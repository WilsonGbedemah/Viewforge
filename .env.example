# ViewForge Environment Configuration
# Copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup required)
DATABASE_URL=sqlite:///./viewforge.db

# ── Browser Profiles ──────────────────────────────────────────────────────────
# Directory where Playwright persistent profiles are stored (one per account)
PROFILES_DIR=./profiles

# ── Browser Mode ──────────────────────────────────────────────────────────────
# Set to "false" during development to see the browser window
HEADLESS=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in productionet
SECRET_KEY=change-me-to-a-long-random-secret

# ── SMS Provider (required for automated account creation) ────────────────────
# Supported providers: sms-activate | 5sim
# sms-activate: get your API key at https://sms-activate.org/profile  (recommended)
# 5sim:         get your API key at https://5sim.net/settings/profile
SMS_PROVIDER=sms-activate
SMS_API_KEY=your_sms_api_key_here
SMS_DEFAULT_COUNTRY=us
