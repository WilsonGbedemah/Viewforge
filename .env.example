# ViewForge Environment Configuration
# Copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, fine for dev and small deployments)
DATABASE_URL=sqlite:///./viewforge.db
# PostgreSQL (required for production / 20,000+ accounts)
# Uncomment and fill in when switching to PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/viewforge

# ── Browser Profiles ──────────────────────────────────────────────────────────
# Directory where Playwright persistent profiles are stored (one per account)
PROFILES_DIR=./profiles

# ── Browser Mode ──────────────────────────────────────────────────────────────
# Set to "false" during development to see the browser window
HEADLESS=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in productionet
SECRET_KEY=change-me-to-a-long-random-secret

# ── Rotating Proxy (required for unique IP per account at scale) ─────────────
# Each auto-created account gets its own sticky-session IP.
# Supports Smartproxy, IPRoyal, BrightData, and any sticky-session provider.
# Leave blank to skip (all accounts will share one IP — not recommended).
ROTATING_PROXY_HOST=gate.smartproxy.com
ROTATING_PROXY_PORT=10000
ROTATING_PROXY_USERNAME=user
ROTATING_PROXY_PASSWORD=your_rotating_proxy_password_here
ROTATING_PROXY_PROTOCOL=http

# ── SMS Provider (required for automated account creation) ────────────────────
# Supported providers: sms-activate | 5sim
# sms-activate: get your API key at https://sms-activate.org/profile  (recommended)
# 5sim:         get your API key at https://5sim.net/settings/profile
SMS_PROVIDER=sms-activate
SMS_API_KEY=your_sms_api_key_here
SMS_DEFAULT_COUNTRY=us
